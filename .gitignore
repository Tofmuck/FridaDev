# Secrets and local runtime configuration
.env
.env.local
.env.*.local
app/.env
app/.env.local
app/.env.*.local

# Runtime state and generated data
# Runtime identity files stay local and untracked; only examples/docs are versioned.
state/
!state/data/
state/data/*
!state/data/identity/
state/data/identity/*
!state/data/identity/README.md
!state/data/identity/*.example.txt
app/conv/
app/data/
# Runtime log artifacts (keep app/logs source package trackable)
app/logs/*.jsonl
app/logs/*.log
# Python caches and environments
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Coverage and reports
.coverage
htmlcov/

# OS / editor files
.DS_Store
._*
.vscode/
.idea/
*.swp

# Temporary and backup files
*.bak
*.tmp
*.tmpcodex
*.corrupt-*.json
*.dump
*.sql
*.tar.gz

# Local Codex CLI residue
.codex

# Local Claude/Codex desktop settings
.claude/
