# Core runtime
FRIDA_WEB_PORT=8089
FRIDA_WEB_HOST=0.0.0.0
FRIDA_TIMEOUT=900
FRIDA_MAX_TOKENS=35000
FRIDA_TIMEZONE=Europe/Paris

# Admin API security
FRIDA_ADMIN_TOKEN=
FRIDA_ADMIN_LAN_ONLY=0
FRIDA_ADMIN_ALLOWED_CIDRS=127.0.0.1/32,::1/128
FRIDA_ADMIN_LOG_PATH=/app/logs/admin.log.jsonl
FRIDA_ADMIN_LOG_MAX_BYTES=5242880
FRIDA_ADMIN_LOG_MAX_FILES=14

# OpenRouter
OPENROUTER_BASE=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5.1
OPENROUTER_API_KEY=
OPENROUTER_REFERER=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=FridaDev
OPENROUTER_TITLE_LLM=FridaDev/LLM
OPENROUTER_TITLE_ARBITER=FridaDev/Arbiter
OPENROUTER_TITLE_RESUMER=FridaDev/Resumer
# Search
SEARXNG_URL=http://127.0.0.1:8092
SEARXNG_RESULTS=5

# Crawl4AI
CRAWL4AI_URL=http://127.0.0.1:11235
CRAWL4AI_TOKEN=
CRAWL4AI_TOP_N=2
CRAWL4AI_MAX_CHARS=5000
CRAWL4AI_EXPLICIT_URL_MAX_CHARS=25000

# Identity / prompts
FRIDA_LLM_IDENTITY_PATH=data/identity/llm_identity.txt
FRIDA_USER_IDENTITY_PATH=data/identity/user_identity.txt
ARBITER_MODEL=openai/gpt-5.4-mini
ARBITER_TIMEOUT_S=10
ARBITER_PROMPT_PATH=prompts/arbiter.txt
IDENTITY_EXTRACTOR_PROMPT_PATH=prompts/identity_extractor.txt

# Memory storage (PostgreSQL + pgvector)
FRIDA_MEMORY_DB_DSN=postgresql://user:password@127.0.0.1:5432/fridadev
FRIDA_RUNTIME_SETTINGS_CRYPTO_KEY=
EMBED_BASE_URL=https://embed.example.com
EMBED_TOKEN=
EMBED_DIM=384
MEMORY_TOP_K=5

# Identity dynamics
IDENTITY_DECAY_FACTOR=0.95
IDENTITY_TOP_N=15

# Summaries
SUMMARY_THRESHOLD_TOKENS=35000
SUMMARY_TARGET_TOKENS=2000
SUMMARY_KEEP_TURNS=5
SUMMARY_MODEL=openai/gpt-5.4-mini

# Hermeneutics (seed thresholds)
# Modes: off | shadow | enforced_identities | enforced_all
HERMENEUTIC_SCHEMA_VERSION=v1
HERMENEUTIC_MODE=shadow
ARBITER_MIN_SEMANTIC_RELEVANCE=0.62
ARBITER_MIN_CONTEXTUAL_GAIN=0.55
ARBITER_MAX_KEPT_TRACES=3
IDENTITY_MIN_CONFIDENCE=0.72
IDENTITY_DEFER_MIN_CONFIDENCE=0.58
IDENTITY_MIN_RECURRENCE_FOR_DURABLE=2
IDENTITY_RECURRENCE_WINDOW_DAYS=30
IDENTITY_PROMOTION_MIN_DISTINCT_CONVERSATIONS=2
IDENTITY_PROMOTION_MIN_TIME_GAP_HOURS=6
CONTEXT_HINTS_MAX_ITEMS=2
CONTEXT_HINTS_MAX_TOKENS=120
CONTEXT_HINTS_MAX_AGE_DAYS=7
CONTEXT_HINTS_MIN_CONFIDENCE=0.60
IDENTITY_MAX_TOKENS=500
